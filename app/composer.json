{
  "name": "budget-bot/app",
  "type": "project",
  "require": {
    "php": "^8.4",
    "ext-swoole": "^6.0",
    "ext-pdo_pgsql": "*",
    "ext-memcached": "*",
    "ext-json": "*",
    "php-di/php-di": "^7.0",
    "nikic/fast-route": "^1.3",
    "monolog/monolog": "^3.9",
    "vlucas/phpdotenv": "^5.6",
    "guzzlehttp/guzzle": "^7.10",
    "phptg/bot-api": "^0.12"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/",
      "Database\\": "database/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "require-dev": {
    "dg/bypass-finals": "^1.10",
    "mockery/mockery": "^1.6",
    "phpunit/phpunit": "^12",
    "swoole/ide-helper": "^6.0"
  }
}
