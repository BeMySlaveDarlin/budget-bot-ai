APP_ENV=dev
APP_NAME=budget-bot
APP_DEBUG=true
TIMEZONE=Asia/Bangkok
COMPOSE_PROJECT_NAME=budget-bot

SWOOLE_HOST=0.0.0.0
SWOOLE_PORT=9501
SWOOLE_EXTERNAL_PORT=9501
SWOOLE_WORKERS=4
SWOOLE_TASK_WORKERS=2
SWOOLE_MAX_COROUTINE=10000

DB_HOST=database
DB_PORT=5432
DB_EXTERNAL_PORT=5432
DB_DATABASE=budget_db
DB_USERNAME=budget_user
DB_PASSWORD=budget_secret
DB_POOL_MIN=2
DB_POOL_MAX=10

MEMCACHED_HOST=memcached
MEMCACHED_PORT=11211

LOG_LEVEL=debug

BUDGET_BOT_TOKEN=
MEALS_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# true — не слать реальные запросы в Telegram API (локалка/e2e), только логировать
TELEGRAM_DRY_RUN=false

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
EXCHANGERATE_API_KEY=

DEFAULT_CURRENCY=THB
